# ═════════════════════════════════════════════════════════════════════════════
# VANTAGE: Deployment Environment Configuration
# Copy this file to '.env' and modify for your local/VPS setup.
# ═════════════════════════════════════════════════════════════════════════════

# Vantage Environment: TEST (local development) veya PROD (production VPS)
VANTAGE_ENV=TEST

# ── Domain Settings ──────────────────────────────────────────────────────────
# TEST modunda 'localhost' kullanılır, PROD modunda gerçek alan adları yazılır.
DOMAIN=localhost
ADMIN_DOMAIN=localhost

# SSL Sertifikası için Let's Encrypt İletişim E-postası (PROD modunda gereklidir)
CADDY_EMAIL=admin@vantage.local

# ── Dashboard Obfuscation (Gizli URL Path) ──────────────────────────────────
# Admin paneline erişimi gizlemek için rastgele/uzun bir path belirleyin.
# Yalnızca bu path'e ilk kez giden tarayıcılar admin paneline erişebilir.
# Örnek Giriş Linki: http://localhost/vantage-ops-secret-777
ADMIN_PATH_SECRET=vantage-ops-secret-777

# ── Caddy Admin Basic Auth (Çift Katmanlı Koruma) ───────────────────────────
# PROD modunda admin panelini ekstradan Basic Auth ile korumak için hash girin.
# Boş bırakılırsa Basic Auth devre dışı kalır.
# Üretmek için: docker run --rm caddy caddy hash-password -plaintext "sifreniz"
ADMIN_PASS_HASH=

# ── Port Konfigürasyonları (Host Portları) ───────────────────────────────────
# Host makinede kullanılacak portlar. Başka servislerle çakışıyorsa değiştirebilirsiniz.
HOST_ADMIN_PORT=3333
HOST_PHISH_HTTP_PORT=80
HOST_PHISH_HTTPS_PORT=443
HOST_CHISEL_PORT=9090

# ── İlk Admin Şifresi ────────────────────────────────────────────────────────
# Boş bırakılırsa Gophish rastgele bir şifre üretir ve sadece container
# loglarına yazar. ./scripts/setup.sh bunu otomatik doldurur ve kurulum
# sonunda ekrana yazdırır — elle dolduracaksanız en az 8 karakter olmalı.
GOPHISH_INITIAL_ADMIN_PASSWORD=
