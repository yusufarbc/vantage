# ═════════════════════════════════════════════════════════════════════════════
# VANTAGE: Unified Caddy Reverse Proxy Configuration (Dev & Prod)
# Handles: TLS termination, Basic Auth, WebSocket, Security headers,
# and Admin Dashboard Obfuscation (Secret URL Path)
# ═════════════════════════════════════════════════════════════════════════════

{
    # Global option: contact email for Let's Encrypt certificates
    email {$CADDY_EMAIL:admin@vantage.local}
    
    # Keep admin API local
    admin localhost:2019
    
    log {
        level info
        format json
    }
}

# ═════════════════════════════════════════════════════════════════════════════
# Enterprise Security Headers Snippet
# ═════════════════════════════════════════════════════════════════════════════
(security_headers) {
    # Prevent clickjacking
    header X-Frame-Options "DENY"
    
    # Prevent MIME sniffing
    header X-Content-Type-Options "nosniff"
    
    # XSS protection
    header X-XSS-Protection "1; mode=block"
    
    # Referrer policy
    header Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content Security Policy (adjusted for Vantage UI requirements)
    header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self' ws: wss:;"

    # HSTS (HTTP Strict Transport Security)
    header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    
    # Permissions Policy
    header Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
}

# ═════════════════════════════════════════════════════════════════════════════
# Admin Dashboard & API (Hiding behind {$ADMIN_PATH_SECRET})
# ═════════════════════════════════════════════════════════════════════════════
{$ADMIN_DOMAIN:localhost} {
    import security_headers
    
    # 🔐 Admin Obfuscation Entrance
    # Visiting this URL sets a 30-day vantage_access cookie and redirects to Gophish Admin UI
    route /{$ADMIN_PATH_SECRET} {
        header +Set-Cookie "vantage_access=authorized; Path=/; Max-Age=2592000; HttpOnly; SameSite=Lax"
        redir * /
    }

    # 🛑 Authorization Verification WAF
    # Denies any request to Gophish Admin UI unless they have the cookie or are visiting the entry point.
    route {
        @unauthorized {
            not path /{$ADMIN_PATH_SECRET}*
            not header Cookie *vantage_access=authorized*
        }
        # Returns a generic 404 to hide the server's identity from scanners and bots
        respond @unauthorized "Not Found" 404
    }

    # Conditional Basic Authentication for Admin UI
    # Enabled only if the ADMIN_PASS_HASH env variable is defined on the host.
    # Generate bcrypt hash: docker run --rm caddy caddy hash-password -plaintext "mysecret"
    @has_auth expression {env.ADMIN_PASS_HASH} != "disabled"
    basicauth @has_auth {
        vantage-admin {$ADMIN_PASS_HASH}
    }
    
    reverse_proxy vantage-core:3333 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    encode gzip
    
    log {
        output file /var/log/caddy/admin_access.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
    }
}

# ═════════════════════════════════════════════════════════════════════════════
# Phishing Redirectors & Campaign Landing Pages
# ═════════════════════════════════════════════════════════════════════════════
{$PHISH_DOMAIN:http://*, https://*} {
    import security_headers
    
    # No Authentication - Public Facing
    reverse_proxy vantage-core:8080 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    encode gzip
    
    log {
        output file /var/log/caddy/phish_access.log {
            roll_size 50mb
            roll_keep 10
        }
        format json
    }
}
